{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": ["src/assets/fonts"], // Ignore submodules

	"useTabs": true,
	"tabWidth": 2,
	"sortImports": true,
	"proseWrap": "always",

	"overrides": [
		// Don't add trailing commas in .jsonc files (it causes a bunch of warnings)
		{ "files": ["**/*.jsonc"], "options": { "trailingComma": "none" } }
	]
}
