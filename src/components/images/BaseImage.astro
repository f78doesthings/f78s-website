---
import type { Props as PictureProps } from "astro/components/Picture.astro";
import { Picture as LqipPicture, type LqipType } from "astro-lqip/components";
import { Picture } from "astro:assets";

export type Props = PictureProps & {
	/** Enables LQIP if present and not false. Can also be a string value for the LQIP type. */
	lqip?: boolean | LqipType;

	/** The LQIP size in pixels (4..64). Defaults to 4. */
	lqipSize?: number;
};

const { lqip, lqipSize, ...props } = Astro.props;
props.formats ??= ["avif", "webp"];
props.fallbackFormat ??= "jpg";
props.densities ??= [1, 2];

// TODO: a custom LQIP solution would be more ideal, but maybe later
---

{lqip ? <LqipPicture lqip={lqip === true ? undefined : lqip} lqipSize={lqipSize} {...props} /> : <Picture {...props} />}

<style lang="scss">
	picture, img {
		border-radius: 1rem;
	}
</style>
