// A (currently simple) video player.

import type { HTMLAttributes } from "astro/types";
import type { MediaInfo, Replace } from "../../../types.ts";
import { resolveMedia } from "../../../server-utils";
import { VideoPlayerClient } from "./VideoPlayerClient";

type Props = Replace<
	HTMLAttributes<"video">,
	MediaInfo & {
		/** The width of the video in pixels. This is enforced for now to prevent layout shift. */
		width: number;

		/** The height of the video in pixels. This is enforced for now to prevent layout shift. */
		height: number;
	}
>;

const { src, license = "CC-BY-SA-4.0", ...props } = Astro.props;
const resolvedSrc = await resolveMedia(src);
if (!resolvedSrc) {
	throw new Error(`Could not resolve media source: ${src}`);
}
---

<figure>
	<VideoPlayerClient client:visible src={resolvedSrc} license={license} {...props as any} />
	<figcaption>
		<slot />
	</figcaption>
</figure>
