---
import { Icon } from "astro-icon/components";
import type { HTMLAttributes } from "astro/types";
import { isOnPage } from "../../utils.ts";

interface Props extends HTMLAttributes<"a"> {
	icon?: string;
	iconSize?: number;
}

const { href, icon, ...props } = Astro.props;
const isActive = isOnPage(Astro.url, import.meta.env.BASE_URL, href ?? "/preferences");
---

<a href={href} tabindex="0" {...props}>
	{icon && <Icon name={icon} class="icon" />}
	<slot />
	{isActive &&
		<div class="highlight"></div>}
</a>

<style lang="scss">
	@use "../../styles/colors" as *;
	@use "../../styles/utils" as *;
	@use "sass:color";

	.icon {
		font-size: 1.25rem;
	}

	a {
		display: flex;
		align-items: center;
		color: var(--color-text);
		text-decoration: none;

		gap: 0.25rem;
		font-family: var(--font-heading), sans-serif;

		@include btn-transparent;
	}

	:global(.hamburger-menu) {
		a {
			gap: 0.375rem;
			font-size: 1.0625rem;
		}

		.icon {
			font-size: size(30);
		}

		.highlight {
			background: linear-gradient(to right, $red-500, $red-600);
			left: unset;
			right: 0;
			width: 0.1875rem;
			height: 100%;
		}
	}

	.highlight {
		position: absolute;
		left: 0;
		bottom: 0;
		width: 100%;
		height: 0.1875rem;
		background: linear-gradient($red-500, $red-600);

		:root.immersive-effects &::after {
			content: "";
			position: absolute;
			inset: 0;

			background: inherit;
			filter: blur(0.1875rem);
			opacity: 0.5;
		}
	}
</style>
