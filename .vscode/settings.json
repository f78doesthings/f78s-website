{
	// Linting
	"astro.content-intellisense": true,
	"markdown.validate.enabled": true,
	"stylelint.validate": ["css", "postcss", "scss", "astro"],
	"css.validate": false,
	"scss.validate": false,

	// Formatting
	"editor.insertSpaces": false,
	"editor.rulers": [100],
	"editor.defaultFormatter": "oxc.oxc-vscode",
	"[astro]": {
		"editor.defaultFormatter": "astro-build.astro-vscode"
	},
	"[mdx]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},

	// Spellcheck (optional, for Code Spell Checker w/ British English dictionary)
	"cSpell.language": "en-GB",

	// Copyright (WIP)
	"psi-header.config": {
		"forceToTop": true,
		"blankLinesAfter": 1,
		"author": "f78",
		"license": "MPL-2.0"
	},
	"psi-header.changes-tracking": {
		"isActive": true,
		"enforceHeader": true,
		"excludeGlob": ["**/settings.json", "**/.gitignore", "**/.gitattributes", "**/.gitmodules"],
		"exclude": ["json", "jsonc", "plaintext", "markdown", "mdx"]
	},
	"psi-header.templates": [
		{
			"language": "*",
			"template": [
				"Copyright (c) <<year>> <<author>>.",
				"",
				"This Source Code Form is subject to the terms of the Mozilla Public",
				"License, v. 2.0. If a copy of the MPL was not distributed with this",
				"file, You can obtain one at https://mozilla.org/MPL/2.0/."
			]
		}
	],
	"psi-header.lang-config": [
		{
			// BUG: this likes to insert a bogus --- after the header
			"language": "astro",
			"beforeHeader": ["---"]
		},
		{
			"language": "scss",
			"begin": "/*!"
		}
	]
}
